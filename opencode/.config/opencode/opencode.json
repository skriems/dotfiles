{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "models": {
        "deepseek-r1": {
          "_launch": true,
          "name": "deepseek-r1"
        },
        "gpt-oss": {
          "_launch": true,
          "name": "gpt-oss"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "spokenly": {
      "enabled": false,
      "type": "remote",
      "url": "http://localhost:51089"
    }
  }
}
